# --- Rust (NIF build artifacts) ---
# `**/` so umbrella paths like apps/atlas/native/*/target are also caught.
**/native/*/target/

# --- Compiled NIF artifacts (built from native/ on mix compile) ---
**/priv/native/

# --- Runtime data (library DBs, object store, logs) ---
**/priv/data/

# --- Dialyzer ---
/.plts/
**/priv/plts/
*.plt
*.plt.hash

# --- SQLite ---
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Escript binary output (mix escript.build) ---
/atlas

# --- Logs + pid files (daemon mode, Phase 2) ---
*.log
*.pid

# --- Environment / secrets ---
.env
.env.*
.envrc

# --- Node / Phoenix assets (Tailwind + esbuild binaries live here) ---
# Only the installers are cached under deps/tailwind and deps/esbuild,
# and deps/ is already ignored, but exclude any app-local node_modules.
node_modules/

# --- Temp dirs ---
/tmp/

# --- Editors / IDEs ---
.vscode/
.idea/
.cursor/
*.iml
*.swp
*.swo
*~

